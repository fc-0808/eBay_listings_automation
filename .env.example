# Copy to .env and fill in. Never commit .env.

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# RuName string shown in the portal after you save redirect settings (NOT the http:// URL).
# OAuth authorize + token calls use this as redirect_uri. See README "RuName vs URL".
EBAY_RU_NAME=

# Where your machine listens — must match "Auth Accepted URL" for that RuName exactly.
EBAY_OAUTH_CALLBACK_URL=http://127.0.0.1:8765/oauth/callback

# sandbox | production
EBAY_ENV=sandbox

# Optional override (default: .ebay_tokens.json in project root)
# EBAY_TOKEN_PATH=.ebay_tokens.json
