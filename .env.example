# Copy to .env and fill in. Never commit .env.

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Must match your app's OAuth redirect (RuName) exactly — same scheme, host, port, path.
EBAY_REDIRECT_URI=http://127.0.0.1:8765/oauth/callback

# sandbox | production
EBAY_ENV=sandbox

# Optional override (default: .ebay_tokens.json in project root)
# EBAY_TOKEN_PATH=.ebay_tokens.json
