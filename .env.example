# Copy to .env and fill in. Never commit .env.

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# RuName string shown in the portal after you save redirect settings (NOT the callback URL).
EBAY_RU_NAME=

# Must match "Auth Accepted URL" in the portal exactly. eBay requires HTTPS there — see README.
EBAY_OAUTH_CALLBACK_URL=https://127.0.0.1:8765/oauth/callback

# When using https:// above, PEM files for the local listener (e.g. from mkcert 127.0.0.1):
# EBAY_OAUTH_SSL_CERTFILE=C:\path\to\127.0.0.1.pem
# EBAY_OAUTH_SSL_KEYFILE=C:\path\to\127.0.0.1-key.pem

# sandbox | production
EBAY_ENV=sandbox

# Optional override (default: .ebay_tokens.json in project root)
# EBAY_TOKEN_PATH=.ebay_tokens.json
