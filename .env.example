# Copy to .env and fill in. Never commit .env.

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# RuName string from the portal (OAuth redirect_uri value).
EBAY_RU_NAME=

# Must match eBay "Auth accepted URL" exactly. Default: HTTPS on this machine (mkcert).
EBAY_OAUTH_CALLBACK_URL=https://127.0.0.1:8765/oauth/callback

# PEM paths from: mkcert -install  then  mkcert 127.0.0.1
# (or: mkcert local.host after adding 127.0.0.1 local.host to your hosts file)
EBAY_OAUTH_SSL_CERTFILE=
EBAY_OAUTH_SSL_KEYFILE=

# Only if using a tunnel (ngrok, etc.): public https URL above, local http listen below.
# EBAY_OAUTH_LISTEN_URL=http://127.0.0.1:8765/oauth/callback

# sandbox | production
EBAY_ENV=sandbox

# EBAY_TOKEN_PATH=.ebay_tokens.json
