# Copy to .env and fill in. Never commit .env.

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# RuName string from the portal (OAuth redirect_uri value).
EBAY_RU_NAME=

# Must match eBay "Auth accepted URL" exactly.
EBAY_OAUTH_CALLBACK_URL=https://127.0.0.1:8765/oauth/callback

# After: mkcert -install  then  mkcert 127.0.0.1  (in this folder; files are gitignored)
EBAY_OAUTH_SSL_CERTFILE=./127.0.0.1.pem
EBAY_OAUTH_SSL_KEYFILE=./127.0.0.1-key.pem

# Only for tunnels (ngrok, etc.):
# EBAY_OAUTH_LISTEN_URL=http://127.0.0.1:8765/oauth/callback

# sandbox | production
EBAY_ENV=sandbox

# EBAY_TOKEN_PATH=.ebay_tokens.json
